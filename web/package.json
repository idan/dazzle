{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build:wasm": "wasm-pack build ../renderer --target web --out-dir ../web/src/lib/renderer-wasm --out-name renderer --release",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wrangler": "^4.97.0"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/lint": "^6.9.7",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.1",
		"@lezer/highlight": "^1.2.3",
		"bits-ui": "^2.18.1",
		"codemirror": "^6.0.2"
	}
}
